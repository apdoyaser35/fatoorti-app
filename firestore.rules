rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // Helper Functions
    // =========================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =========================
    // Users
    // =========================
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && 
                   request.resource.data.keys().hasAll(['username', 'role', 'active']) &&
                   (!('phone_number' in request.resource.data) || request.resource.data.phone_number is string);

      allow update: if isAdmin() || (isOwner(userId) && 
                    (!('phone_number' in request.resource.data) || request.resource.data.phone_number is string) &&
                    request.resource.data.role == resource.data.role);

      allow delete: if isAdmin();
    }

    // =========================
    // Branches
    // =========================
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =========================
    // Delivery Companies
    // =========================
    match /delivery_companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =========================
    // Invoices (🔥 المهم)
    // =========================
    match /invoices/{invoiceId} {

      // قراءة (للسماح بجلب آخر فاتورة لإنشاء رقم تسلسلي)
      allow read: if isAuthenticated();

      // إنشاء (الموظف يرفع فاتورة)
      // Check for either image_urls (legacy) or attachments
      allow create: if isAuthenticated()
        && request.resource.data.employee_id == request.auth.uid
        && request.resource.data.invoice_number is string
        && request.resource.data.branch_id is string
        && (!('delivery_company_id' in request.resource.data) || request.resource.data.delivery_company_id is string)
        && (!('notes' in request.resource.data) || request.resource.data.notes is string)
        && (!('phone_number' in request.resource.data) || request.resource.data.phone_number is string)
        && (
          (request.resource.data.keys().hasAll(['attachments']) && request.resource.data.attachments is list) ||
          (request.resource.data.keys().hasAll(['image_urls']) && request.resource.data.image_urls is list)
        );

      // تعديل / حذف (أدمن أو الموظف اللي رفعها)
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.employee_id == request.auth.uid);
    }
  }
}